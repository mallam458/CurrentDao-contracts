{
  "extends": "solhint:recommended",
  "plugins": [],
  "rules": {
    "compiler-version": ["error", "^0.8.19"],
    "avoid-throw": "off",
    "avoid-suicide": "error",
    "avoid-sha3": "warn",
    "constructor-syntax": "error",
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "gas-globals": "error",
    "indent": ["error", 4],
    "linter-length": "off",
    "max-line-length": ["warn", 120],
    "max-states-count": ["warn", 15],
    "no-empty-blocks": "warn",
    "no-global-imports": "error",
    "no-imports-from-tests": "error",
    "no-mix-tabs-and-spaces": "error",
    "no-spaces-before-function-parentheses": "off",
    "not-rely-on-time": "warn",
    "operator-whitespace": "error",
    "quotes": ["error", "double"],
    "reason-string": ["warn", { "maxLength": 50 }],
    "semicolon-whitespace": "error",
    "solidity-constructor-align": "error",
    "solidity-events-order": "error",
    "solidity-modifiers-order": "error",
    "solidity-ordered-imports": "error",
    "solidity-private-vars-leading-underscore": "error",
    "solidity-shorthand": "error",
    "solidity-tuple-array-whitespace": "error",
    "solidity-upgrade-to-0.8.0": "error",
    "style-guide-casing": "error",
    "var-name-mixedcase": "error",
    "whitespace": "error"
  }
}
