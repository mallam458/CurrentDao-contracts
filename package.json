{
  "name": "currentdao-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for the CurrentDao solar energy ecosystem on Stellar/Soroban.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:acl": "NODE_OPTIONS=--experimental-vm-modules jest tests/acl/AccessControlList.test.ts",
    "test:emergency": "NODE_OPTIONS=--experimental-vm-modules jest tests/emergency",
    "test:fees": "NODE_OPTIONS=--experimental-vm-modules jest tests/fees/FeeManager.test.ts",
    "test:security": "NODE_OPTIONS=--experimental-vm-modules jest tests/security/SecurityMonitor.test.ts",
    "test:security:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/security/SecurityIntegration.test.ts",
    "test:analytics": "NODE_OPTIONS=--experimental-vm-modules jest tests/analytics/UsageAnalytics.test.ts",
    "test:upgrade": "NODE_OPTIONS=--experimental-vm-modules jest tests/upgrade/UpgradeManager.test.ts",
    "test:rating": "NODE_OPTIONS=--experimental-vm-modules jest tests/rating/QualityRating.test.ts",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "echo 'Linting not configured yet'",
    "deploy:acl": "node --loader ts-node/esm scripts/deploy_acl.ts",
    "deploy:emergency": "node --loader ts-node/esm scripts/deploy_emergency.ts",
    "deploy:fees": "node --loader ts-node/esm scripts/deploy_fees.ts",
    "deploy:security:dev": "node --loader ts-node/esm scripts/deploy_security_monitor.ts development",
    "deploy:security:testnet": "node --loader ts-node/esm scripts/deploy_security_monitor.ts testnet",
    "deploy:security:mainnet": "node --loader ts-node/esm scripts/deploy_security_monitor.ts mainnet",
    "deploy:analytics": "node --loader ts-node/esm scripts/deploy_usage_analytics.ts",
    "deploy:upgrade": "node --loader ts-node/esm scripts/deploy_upgrade.ts",
    "deploy:rating:dev": "node --loader ts-node/esm -e \"import { deployRatingSystem } from './scripts/deploy_rating.js'; deployRatingSystem('development').then(console.log).catch(console.error);\"",
    "deploy:rating:testnet": "node --loader ts-node/esm -e \"import { deployRatingSystem } from './scripts/deploy_rating.js'; deployRatingSystem('testnet').then(console.log).catch(console.error);\"",
    "deploy:rating:mainnet": "node --loader ts-node/esm -e \"import { deployRatingSystem } from './scripts/deploy_rating.js'; deployRatingSystem('mainnet').then(console.log).catch(console.error);\"",
    "build": "tsc",
    "verify:fees": "ts-node -e \"const { FeeSystemDeployer } = require('./scripts/deploy_fees'); const deployer = new FeeSystemDeployer({network: 'development', owner: '0xowner', treasury: '0xtreasury', validators: '0xvalidators', developers: '0xdevelopers', enableDynamicFees: true, initialNetworkCongestion: 20}); deployer.verifyDeployment({feeManager: new (require('./contracts/fees/FeeManager').FeeManager)('0xowner'), config: deployer.config, deploymentHash: 'test', timestamp: Date.now(), gasUsed: 0}).then(console.log);\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codekill33/CurrentDao-contracts.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Codekill33/CurrentDao-contracts/issues"
  },
  "homepage": "https://github.com/Codekill33/CurrentDao-contracts#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
