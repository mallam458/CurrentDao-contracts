{
  "name": "currentdao-carbon-credit-trading",
  "version": "1.0.0",
  "description": "Carbon credit trading marketplace for CurrentDao sustainability initiatives",
  "main": "index.js",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "hardhat test --grep \"GasOptimization\"",
    "deploy": "hardhat run scripts/deploy.js",
    "verify": "hardhat verify --network",
    "coverage": "hardhat coverage",
    "lint": "solhint 'contracts/**/*.sol'",
    "size": "hardhat size-contracts",
    "gas-report": "REPORT_GAS=true hardhat test"
  },
  "keywords": [
    "carbon-credits",
    "sustainability",
    "defi",
    "marketplace",
    "currentdao",
    "environmental",
    "trading"
  ],
  "author": "CurrentDao",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.0",
    "hardhat": "^2.17.0",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.4",
    "solhint": "^3.6.2"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
