{
  "name": "currentdao-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for the CurrentDao solar energy ecosystem on Stellar/Soroban.",
  "main": "index.js",
  "type": "commonjs",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "npx jest",
    "test:token": "npx jest contracts/token",
    "test:dao": "npx jest contracts/dao",
    "test:coverage": "npx jest --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,apps,libs,test}/**/*.ts\"",
    "deploy:token": "ts-node scripts/deploy_token.ts",
    "deploy:dao": "ts-node scripts/deploy_dao.ts",
    "build": "npx tsc",
    "verify:token": "ts-node scripts/verify_token.ts",
    "verify:dao": "ts-node scripts/verify_dao.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CurrentDao-org/CurrentDao-contracts.git"
  },
  "keywords": ["stellar", "blockchain", "energy", "dao", "soroban", "smart-contracts"],
  "author": "CurrentDao-org",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CurrentDao-org/CurrentDao-contracts/issues"
  },
  "homepage": "https://github.com/CurrentDao-org/CurrentDao-contracts#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^30.3.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
