{
  "name": "@currentdao/upgradeable-system",
  "version": "1.0.0",
  "description": "Comprehensive upgradeable contract system with proxy patterns, secure upgrade mechanisms, version management, and backward compatibility for CurrentDao contract evolution",
  "main": "UpgradeableSystem.ts",
  "scripts": {
    "build": "tsc",
    "test": "ts-node UpgradeableSystem.test.ts",
    "test:watch": "nodemon --exec 'ts-node UpgradeableSystem.test.ts'",
    "lint": "eslint *.ts",
    "format": "prettier --write *.ts",
    "docs": "typedoc --out docs *.ts",
    "security:audit": "ts-node SecurityValidator.ts",
    "gas:optimize": "ts-node GasOptimizer.ts",
    "validate": "npm run lint && npm run test && npm run security:audit"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "upgradeable",
    "proxy-pattern",
    "currentdao",
    "security",
    "gas-optimization",
    "version-management",
    "dao",
    "solidity",
    "typescript"
  ],
  "author": "CurrentDao Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/damianosakwe/CurrentDao-contracts.git",
    "directory": "contracts/upgradeable"
  },
  "bugs": {
    "url": "https://github.com/damianosakwe/CurrentDao-contracts/issues"
  },
  "homepage": "https://github.com/damianosakwe/CurrentDao-contracts/tree/main/contracts/upgradeable",
  "dependencies": {
    "@types/node": "^18.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "nodemon": "^2.0.0",
    "prettier": "^2.0.0",
    "ts-node": "^10.0.0",
    "typedoc": "^0.23.0",
    "typescript": "^4.9.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "*.ts",
    "interfaces/*.ts",
    "libraries/*.ts",
    "structures/*.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": [
      "main",
      "release/*"
    ]
  }
}
